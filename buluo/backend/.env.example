# ============================
# 部落冲突升级提醒平台 - 后端配置
# ============================

# 数据库地址 (SQLite 本地 / PostgreSQL 生产)
# SQLite 本地开发:
DATABASE_URL=sqlite:///./coc_reminder.db
# PostgreSQL 生产示例:
# DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname

# WsPusher 配置
WSPUSHER_API_URL=https://wspush.xyz/api/send
WSPUSHER_API_KEY=your_wspusher_api_key_here

# CORS 前端地址 (逗号分隔)
CORS_ORIGINS=http://localhost:3000,https://coc-reminder.vercel.app

# 调度器间隔 (秒)
SCHEDULER_INTERVAL_SECONDS=60

# 时区
TZ=Asia/Shanghai
